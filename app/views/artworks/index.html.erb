<div style="display:flex;flex-direction:column;gap:2rem;">

  <%# ---- HEADER ---- %>
  <div class="fade-in-up" style="display:flex;align-items:flex-start;justify-content:space-between;">
    <div>
      <h1 style="font-family:'Cormorant Garamond',serif;font-size:2.5rem;font-style:italic;font-weight:300;color:#f0e6d3;">
        All Works
      </h1>
      <p style="font-family:'DM Mono',monospace;font-size:0.7rem;color:#5a4e3a;margin-top:0.25rem;letter-spacing:0.05em;">
        <%= @pagy.count %> paintings in your studio
      </p>
    </div>
    <%= link_to "↓ Export Catalogue", catalogue_artworks_path + ".pdf",
        class: "btn-outline",
        style: "text-decoration:none;display:inline-block;" %>
  </div>

  <%# ---- TOOLBAR ---- %>
  <div class="fade-in-up glass-card" style="padding:1rem 1.25rem;display:flex;flex-direction:column;gap:0.6rem;">

    <%# Row 1: Search + Status filters %>
    <div style="display:flex;align-items:center;gap:0.6rem;flex-wrap:wrap;">
      <%= search_form_for @q, url: artworks_path, html: { style:"display:contents;" } do |f| %>
        <input type="text"
          name="q[title_or_medium_cont]"
          value="<%= params.dig(:q, :title_or_medium_cont) %>"
          placeholder="Search title, medium..."
          style="width:220px;background:#1a1612;border:1px solid #2a251e;border-radius:4px;padding:0.45rem 0.8rem;color:#f0e6d3;font-family:'DM Mono',monospace;font-size:0.72rem;outline:none;transition:border-color 0.2s;" />
        <input type="number"
          name="q[year_created_eq]"
          value="<%= params.dig(:q, :year_created_eq) %>"
          placeholder="Year"
          style="width:75px;background:#1a1612;border:1px solid #2a251e;border-radius:4px;padding:0.45rem 0.65rem;color:#f0e6d3;font-family:'DM Mono',monospace;font-size:0.72rem;outline:none;transition:border-color 0.2s;" />
        <button type="submit" class="btn-primary" style="padding:0.45rem 0.9rem;">
          Search
        </button>
        <% if params[:q].present? %>
          <%= link_to "×", artworks_path, style:"font-family:'DM Mono',monospace;font-size:1rem;color:#5a4e3a;text-decoration:none;transition:color 0.2s;",
              onmouseover: "this.style.color='#c4933f'",
              onmouseout: "this.style.color='#5a4e3a'" %>
        <% end %>
      <% end %>

      <div style="width:1px;height:20px;background:#2a251e;margin:0 0.2rem;"></div>

      <%= link_to "All", artworks_path,
          style:"font-family:'DM Mono',monospace;font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;padding:0.35rem 0.8rem;border-radius:20px;text-decoration:none;transition:all 0.25s;border:1px solid #{params[:status].blank? ? '#c4933f' : '#2a251e'};color:#{params[:status].blank? ? '#c4933f' : '#5a4e3a'};background:#{params[:status].blank? ? 'rgba(196,147,63,0.08)' : 'transparent'};" %>
      <% Artwork.statuses.keys.each do |status| %>
        <%= link_to status.humanize, artworks_path(status: status),
            style:"font-family:'DM Mono',monospace;font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;padding:0.35rem 0.8rem;border-radius:20px;text-decoration:none;transition:all 0.25s;border:1px solid #{params[:status] == status ? '#c4933f' : '#2a251e'};color:#{params[:status] == status ? '#c4933f' : '#5a4e3a'};background:#{params[:status] == status ? 'rgba(196,147,63,0.08)' : 'transparent'};" %>
      <% end %>
    </div>

    <%# Row 2: Tags %>
    <% all_tags = Tag.joins(:artworks).where(artworks: { user_id: current_user.id }).distinct.order(:name) %>
    <% if all_tags.any? %>
      <div style="display:flex;align-items:center;gap:0.4rem;flex-wrap:wrap;padding-top:0.4rem;border-top:1px solid rgba(42,37,30,0.5);">
        <span style="font-family:'DM Mono',monospace;font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:#2a251e;">Tags</span>
        <% all_tags.each do |tag| %>
          <%= link_to artworks_path(tag: tag.name),
              style:"font-family:'DM Mono',monospace;font-size:0.62rem;padding:0.2rem 0.6rem;border-radius:3px;text-decoration:none;transition:all 0.25s;border:1px solid #{params[:tag] == tag.name ? '#c4933f' : '#2a251e'};color:#{params[:tag] == tag.name ? '#c4933f' : '#5a4e3a'};background:#{params[:tag] == tag.name ? 'rgba(196,147,63,0.08)' : 'transparent'};" do %>
            #<%= tag.name %>
          <% end %>
        <% end %>
        <% if params[:tag].present? %>
          <%= link_to "× clear", artworks_path, style:"font-family:'DM Mono',monospace;font-size:0.6rem;color:#5a4e3a;text-decoration:none;transition:color 0.2s;",
              onmouseover: "this.style.color='#c4933f'",
              onmouseout: "this.style.color='#5a4e3a'" %>
        <% end %>
      </div>
    <% end %>

  </div>

  <%# ---- GRID ---- %>
  <% if @artworks.any? %>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      <% @artworks.each_with_index do |artwork, idx| %>
        <%= link_to artwork_path(artwork.slug), class: "group fade-in-up stagger-#{(idx % 8) + 1}", style: "text-decoration:none;" do %>
          <div class="aspect-square rounded-2xl overflow-hidden artwork-card-wrap glow-border" style="background:#1a1612;">
            <% if artwork.images.attached? %>
              <%= image_tag artwork.images.first,
              class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 artwork-frame" %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center" style="color:#3a3028;">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
              </div>
            <% end %>
            <div class="artwork-hover-overlay">
              <span class="overlay-title"><%= artwork.title %></span>
              <span class="overlay-meta"><%= artwork.medium %> · <%= artwork.year_created %></span>
            </div>
          </div>
          <div class="mt-3">
            <p style="font-family:'Cormorant Garamond',serif;font-size:1rem;font-style:italic;font-weight:300;color:#f0e6d3;line-height:1.3;transition:color 0.2s;" class="truncate">
              <%= artwork.title %>
            </p>
            <p style="font-family:'DM Mono',monospace;font-size:0.6rem;color:#5a4e3a;margin-top:0.2rem;">
              <%= artwork.medium %> · <%= artwork.year_created %>
            </p>
            <span style="display:inline-block;margin-top:0.35rem;font-family:'DM Mono',monospace;font-size:0.55rem;letter-spacing:0.1em;text-transform:uppercase;padding:0.2rem 0.55rem;border-radius:20px;
              background:<%= artwork.available? ? 'rgba(74,124,89,0.15)' : artwork.sold? ? 'rgba(61,107,158,0.15)' : 'rgba(42,37,30,0.5)' %>;
              color:<%= artwork.available? ? '#6ab87a' : artwork.sold? ? '#6a90d8' : '#5a4e3a' %>;
              border:1px solid <%= artwork.available? ? 'rgba(74,124,89,0.25)' : artwork.sold? ? 'rgba(61,107,158,0.25)' : 'rgba(42,37,30,0.5)' %>;">
              <%= artwork.status.humanize %>
            </span>
          </div>
        <% end %>
      <% end %>
    </div>

    <%# ---- PAGINATION ---- %>
    <div class="flex justify-center mt-8">
      <%== pagy_nav(@pagy) %>
    </div>

  <% else %>
    <div class="glass-card fade-in-up" style="text-align:center;padding:4rem 2rem;">
      <div style="width:64px;height:64px;border-radius:50%;background:rgba(196,147,63,0.08);border:1px solid rgba(196,147,63,0.15);display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;color:#c4933f;">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9.06 11.9 8.07-8.06a2.85 2.85 0 1 1 4.03 4.03l-8.06 8.08"/><path d="M7.07 14.94c-1.66 0-3 1.35-3 3.02 0 1.33-2.5 1.52-2 2.02 1.08 1.1 2.49 2.02 4 2.02 2.2 0 4-1.8 4-4.04a3.01 3.01 0 0 0-3-3.02z"/></svg>
      </div>
      <p style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-style:italic;color:#f0e6d3;">Nothing here yet.</p>
      <p style="font-family:'DM Mono',monospace;font-size:0.7rem;color:#3a3028;margin-top:0.5rem;">Your studio is suspiciously clean. Get painting.</p>
      <%= link_to "Add your first artwork →", new_artwork_path,
          class: "btn-outline",
          style: "display:inline-block;margin-top:1.25rem;text-decoration:none;" %>
    </div>
  <% end %>

</div>
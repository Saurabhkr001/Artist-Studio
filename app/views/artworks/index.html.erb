<div style="display:flex;flex-direction:column;gap:2rem;">

  <%# ---- HEADER ---- %>
  <div style="display:flex;align-items:flex-start;justify-content:space-between;">
    <div>
      <h1 style="font-family:'Cormorant Garamond',serif;font-size:2.5rem;font-style:italic;font-weight:300;color:#f0e6d3;">
        All Works
      </h1>
      <p style="font-family:'DM Mono',monospace;font-size:0.7rem;color:#3a3028;margin-top:0.25rem;">
        <%= @pagy.count %> paintings in your studio
      </p>
    </div>
    <%= link_to "↓ Export Catalogue", catalogue_artworks_path + ".pdf", style:"font-family:'DM Mono',monospace;font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;border:1px solid #2a251e;color:#5a4e3a;padding:0.6rem 1.2rem;border-radius:4px;text-decoration:none;" %>
  </div>

  <%# ---- TOOLBAR ---- %>
  <div style="display:flex;flex-direction:column;gap:0.6rem;">

    <%# Row 1: Search + Status filters %>
    <div style="display:flex;align-items:center;gap:0.6rem;flex-wrap:wrap;">
      <%= search_form_for @q, url: artworks_path, html: { style:"display:contents;" } do |f| %>
        <input type="text"
          name="q[title_or_medium_cont]"
          value="<%= params.dig(:q, :title_or_medium_cont) %>"
          placeholder="Search title, medium..."
          style="width:220px;background:#1a1612;border:1px solid #2a251e;border-radius:4px;padding:0.4rem 0.8rem;color:#f0e6d3;font-family:'DM Mono',monospace;font-size:0.72rem;outline:none;" />
        <input type="number"
          name="q[year_created_eq]"
          value="<%= params.dig(:q, :year_created_eq) %>"
          placeholder="Year"
          style="width:75px;background:#1a1612;border:1px solid #2a251e;border-radius:4px;padding:0.4rem 0.65rem;color:#f0e6d3;font-family:'DM Mono',monospace;font-size:0.72rem;outline:none;" />
        <button type="submit" style="background:#c4933f;color:#0e0c09;border:none;border-radius:4px;padding:0.4rem 0.9rem;font-family:'DM Mono',monospace;font-size:0.62rem;letter-spacing:0.15em;text-transform:uppercase;cursor:pointer;">
          Search
        </button>
        <% if params[:q].present? %>
          <%= link_to "×", artworks_path, style:"font-family:'DM Mono',monospace;font-size:1rem;color:#3a3028;text-decoration:none;" %>
        <% end %>
      <% end %>

      <div style="width:1px;height:20px;background:#2a251e;margin:0 0.2rem;"></div>

      <%= link_to "All", artworks_path,
          style:"font-family:'DM Mono',monospace;font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;padding:0.35rem 0.8rem;border-radius:20px;text-decoration:none;border:1px solid #{params[:status].blank? ? '#c4933f' : '#2a251e'};color:#{params[:status].blank? ? '#c4933f' : '#5a4e3a'};" %>
      <% Artwork.statuses.keys.each do |status| %>
        <%= link_to status.humanize, artworks_path(status: status),
            style:"font-family:'DM Mono',monospace;font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;padding:0.35rem 0.8rem;border-radius:20px;text-decoration:none;border:1px solid #{params[:status] == status ? '#c4933f' : '#2a251e'};color:#{params[:status] == status ? '#c4933f' : '#5a4e3a'};" %>
      <% end %>
    </div>

    <%# Row 2: Tags — only if any exist %>
    <% all_tags = Tag.joins(:artworks).where(artworks: { user_id: current_user.id }).distinct.order(:name) %>
    <% if all_tags.any? %>
      <div style="display:flex;align-items:center;gap:0.4rem;flex-wrap:wrap;">
        <span style="font-family:'DM Mono',monospace;font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:#2a251e;">Tags</span>
        <% all_tags.each do |tag| %>
          <%= link_to artworks_path(tag: tag.name),
              style:"font-family:'DM Mono',monospace;font-size:0.62rem;padding:0.2rem 0.6rem;border-radius:3px;text-decoration:none;border:1px solid #{params[:tag] == tag.name ? '#c4933f' : '#2a251e'};color:#{params[:tag] == tag.name ? '#c4933f' : '#5a4e3a'};" do %>
            #<%= tag.name %>
          <% end %>
        <% end %>
        <% if params[:tag].present? %>
          <%= link_to "× clear", artworks_path, style:"font-family:'DM Mono',monospace;font-size:0.6rem;color:#3a3028;text-decoration:none;" %>
        <% end %>
      </div>
    <% end %>

  </div>
  <%# ---- GRID ---- %>
  <% if @artworks.any? %>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      <% @artworks.each do |artwork| %>
        <%= link_to artwork_path(artwork.slug), class: "group" do %>
          <div class="aspect-square bg-stone-100 rounded-2xl overflow-hidden border border-stone-200">
            <% if artwork.images.attached? %>
              <%= image_tag artwork.images.first,
              class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300 artwork-frame" %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center text-stone-400 text-sm">
                No image
              </div>
            <% end %>
          </div>
          <div class="mt-3">
            <p class="font-medium text-stone-900 group-hover:text-stone-600 truncate">
              <%= artwork.title %>
            </p>
            <p class="text-xs text-stone-400 mt-0.5">
              <%= artwork.medium %> · <%= artwork.year_created %>
            </p>
            <span class="inline-block mt-1 text-xs px-2 py-0.5 rounded-full
              <%= artwork.available? ? 'bg-emerald-100 text-emerald-700' :
                  artwork.sold? ? 'bg-blue-100 text-blue-700' :
                  'bg-stone-100 text-stone-500' %>">
              <%= artwork.status.humanize %>
            </span>
          </div>
        <% end %>
      <% end %>
    </div>

    <%# ---- PAGINATION ---- %>
    <div class="flex justify-center mt-8">
      <%== pagy_nav(@pagy) %>
    </div>

  <% else %>
    <div class="text-center py-20 text-stone-400">
      <p class="text-4xl mb-3">🎨</p>
      <p class="text-lg font-medium text-stone-600">Nothing here yet.</p>
      <p class="text-sm mt-1">Your studio is suspiciously clean. Get painting.</p>
      <%= link_to "Add your first artwork →", new_artwork_path,
          class: "mt-4 inline-block text-sm text-stone-900 underline" %>
    </div>
  <% end %>

</div>
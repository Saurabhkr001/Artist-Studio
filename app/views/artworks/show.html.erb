<div class="max-w-5xl mx-auto space-y-10">

  <%# ---- BACK LINK ---- %>
  <%= link_to artworks_path,
      style: "display:inline-flex;align-items:center;gap:0.4rem;font-family:'DM Mono',monospace;font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;color:#5a4e3a;text-decoration:none;transition:color 0.2s;",
      onmouseover: "this.style.color='#c4933f'",
      onmouseout: "this.style.color='#5a4e3a'" do %>
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    All Works
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mt-6 fade-in-up">

    <%# ---- IMAGES ---- %>
    <div class="space-y-3">
      <% if @artwork.images.attached? %>
        <div class="rounded-2xl overflow-hidden glow-border" style="background:#1a1612;cursor:pointer;" onclick="openArtworkLightbox('<%= url_for(@artwork.images.first) %>')">
          <%= image_tag @artwork.images.first,
              class: "w-full h-auto",
              style: "transition:transform 0.5s ease;",
              onmouseover: "this.style.transform='scale(1.02)'",
              onmouseout: "this.style.transform='scale(1)'" %>
        </div>
        <% if @artwork.images.count > 1 %>
          <div class="grid grid-cols-4 gap-2">
            <% @artwork.images.each_with_index do |image, idx| %>
              <div class="aspect-square rounded-lg overflow-hidden glow-border" style="background:#1a1612;cursor:pointer;" onclick="openArtworkLightbox('<%= url_for(image) %>')">
                <%= image_tag image, class: "w-full h-full object-cover",
                    style: "transition:transform 0.3s ease;",
                    onmouseover: "this.style.transform='scale(1.05)'",
                    onmouseout: "this.style.transform='scale(1)'" %>
              </div>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="aspect-square rounded-2xl flex items-center justify-center glass-card" style="color:#3a3028;">
          <div style="text-align:center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 0.75rem;"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
            <p style="font-family:'DM Mono',monospace;font-size:0.7rem;">No image attached</p>
          </div>
        </div>
      <% end %>
    </div>

    <%# ---- DETAILS ---- %>
    <div class="space-y-6">

      <div>
        <div class="flex items-start justify-between">
          <h1 style="font-family:'Cormorant Garamond',serif;font-size:2.5rem;font-style:italic;font-weight:300;color:#f0e6d3;line-height:1.1;">
            <%= @artwork.title %>
          </h1>
          <span style="font-family:'DM Mono',monospace;font-size:0.55rem;letter-spacing:0.1em;text-transform:uppercase;padding:0.3rem 0.75rem;border-radius:20px;white-space:nowrap;margin-top:0.5rem;
            background:<%= @artwork.available? ? 'rgba(74,124,89,0.15)' : @artwork.sold? ? 'rgba(61,107,158,0.15)' : 'rgba(42,37,30,0.5)' %>;
            color:<%= @artwork.available? ? '#6ab87a' : @artwork.sold? ? '#6a90d8' : '#5a4e3a' %>;
            border:1px solid <%= @artwork.available? ? 'rgba(74,124,89,0.25)' : @artwork.sold? ? 'rgba(61,107,158,0.25)' : 'rgba(42,37,30,0.5)' %>;">
            <%= @artwork.status.humanize %>
          </span>
        </div>
        <p style="font-family:'DM Mono',monospace;font-size:0.7rem;color:#8a7a65;margin-top:0.5rem;letter-spacing:0.05em;">
          <%= [@artwork.medium, @artwork.year_created].compact.join(" · ") %>
        </p>
      </div>

      <div class="divider-ochre"></div>

      <% if @artwork.dimensions_cm.present? %>
        <div>
          <p style="font-family:'DM Mono',monospace;font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:#3a3028;margin-bottom:0.4rem;">Dimensions</p>
          <p style="font-family:'Cormorant Garamond',serif;font-size:1.15rem;font-style:italic;color:#d4c5ae;"><%= @artwork.dimensions_cm %> cm</p>
        </div>
      <% end %>

      <% if @artwork.painted_on.present? %>
        <div>
          <p style="font-family:'DM Mono',monospace;font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:#3a3028;margin-bottom:0.4rem;">Date Painted</p>
          <p style="font-family:'Cormorant Garamond',serif;font-size:1.15rem;font-style:italic;color:#d4c5ae;"><%= @artwork.painted_on.strftime("%B %d, %Y") %></p>
        </div>
      <% end %>

      <% if @artwork.description.present? %>
        <div>
          <p style="font-family:'DM Mono',monospace;font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:#3a3028;margin-bottom:0.4rem;">Notes</p>
          <p style="font-family:'DM Mono',monospace;font-size:0.8rem;color:#a89880;line-height:1.8;"><%= @artwork.description %></p>
        </div>
      <% end %>

      <div>
        <p style="font-family:'DM Mono',monospace;font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:#3a3028;margin-bottom:0.4rem;">Portfolio</p>
        <div style="display:flex;align-items:center;gap:0.5rem;">
          <div style="width:6px;height:6px;border-radius:50%;background:<%= @artwork.is_public? ? '#4a7c59' : '#3a3028' %>;"></div>
          <p style="font-family:'DM Mono',monospace;font-size:0.75rem;color:#a89880;">
            <%= @artwork.is_public? ? "Visible on public portfolio" : "Private — not shown publicly" %>
          </p>
        </div>
      </div>

      <%# ---- ACTIONS ---- %>
      <div class="divider"></div>
      <div style="display:flex;align-items:center;gap:1rem;padding-top:0.5rem;">
        <%= link_to "Edit", edit_artwork_path(@artwork.slug),
            class: "btn-primary",
            style: "text-decoration:none;display:inline-block;" %>
        <%= link_to "Delete", artwork_path(@artwork.slug),
            data: {
              turbo_method: :delete,
              turbo_confirm: "Remove \"#{@artwork.title}\" from your studio? This can't be undone."
            },
            style: "font-family:'DM Mono',monospace;font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;color:#6a3030;text-decoration:none;transition:color 0.2s;",
            onmouseover: "this.style.color='#e05555'",
            onmouseout: "this.style.color='#6a3030'" %>
      </div>

    </div>
  </div>

  <% if @artwork.tags.any? %>
    <div class="fade-in-up">
      <p style="font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:#3a3028;margin-bottom:0.5rem;font-family:'DM Mono',monospace;">Tags</p>
      <div style="display:flex;flex-wrap:wrap;gap:0.4rem;">
        <% @artwork.tags.each do |tag| %>
          <%= link_to artworks_path(tag: tag.name), style:"font-family:'DM Mono',monospace;font-size:0.65rem;padding:0.25rem 0.6rem;background:rgba(196,147,63,0.08);color:#c4933f;border:1px solid rgba(196,147,63,0.15);border-radius:3px;text-decoration:none;transition:all 0.2s;",
              onmouseover: "this.style.background='rgba(196,147,63,0.15)';this.style.borderColor='#c4933f'",
              onmouseout: "this.style.background='rgba(196,147,63,0.08)';this.style.borderColor='rgba(196,147,63,0.15)'" do %>
            #<%= tag.name %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ---- LETTERS TO FUTURE ME ---- %>
  <div class="fade-in-up" style="border-top: 1px solid #2a251e; padding-top: 3rem; margin-top: 3rem;">

    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem;">
      <div>
        <h2 class="font-display" style="font-size: 1.8rem; font-style: italic; color: #f0e6d3;">
          Letters to Future Me
        </h2>
        <p style="font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: #3a3028; margin-top: 0.3rem; font-family:'DM Mono',monospace;">
          Private notes — never shown publicly
        </p>
      </div>
    </div>

    <%# Existing letters %>
    <% if @artwork.studio_notes.any? %>
      <div style="display: grid; gap: 1.5rem; margin-bottom: 3rem;">
        <% @artwork.studio_notes.order(written_on: :desc).each do |note| %>
          <div class="glass-card" style="padding: 1.5rem; position: relative;">
            <p style="font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: #3a3028; margin-bottom: 0.75rem; font-family:'DM Mono',monospace;">
              <%= note.written_on&.strftime("%B %d, %Y") || "Undated" %>
            </p>
            <p style="color: #a89880; font-size: 0.85rem; line-height: 1.9; white-space: pre-wrap; font-family:'DM Mono',monospace;">
              <%= note.body %>
            </p>
            <div style="margin-top: 1.25rem; padding-top: 1rem; border-top: 1px solid rgba(42,37,30,0.5);">
              <%= link_to "Remove",
                  studio_note_path(note),
                  data: { turbo_method: :delete, turbo_confirm: "Remove this letter? It's gone forever." },
                  style: "font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase; color: #2a251e; text-decoration: none; font-family:'DM Mono',monospace; transition: color 0.2s;",
                  onmouseover: "this.style.color='#6a3030'",
                  onmouseout: "this.style.color='#2a251e'" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="glass-card" style="text-align: center; padding: 3rem; margin-bottom: 2rem; border-style:dashed;">
        <p class="font-display" style="font-size: 1.3rem; font-style: italic; color: #3a3028;">
          No letters yet.
        </p>
        <p style="font-size: 0.65rem; color: #2a251e; margin-top: 0.5rem; letter-spacing: 0.1em; font-family:'DM Mono',monospace;">
          Write something to your future self about this painting.
        </p>
      </div>
    <% end %>

    <%# New letter form %>
    <%= form_with model: [@artwork, StudioNote.new],
    url: artwork_studio_notes_path(artwork_slug: @artwork.slug),
        local: false,
        html: { style: "display: grid; gap: 1rem;" } do |f| %>
      <div>
        <%= f.label :body, "Write a letter",
            style: "display: block; font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: #3a3028; margin-bottom: 0.5rem; font-family:'DM Mono',monospace;" %>
        <%= f.text_area :body,
            rows: 6,
            placeholder: "What were you thinking when you made this? What do you want to remember?",
            style: "
              width: 100%;
              background: #1a1612;
              border: 1px solid #2a251e;
              border-radius: 6px;
              padding: 1rem;
              color: #f0e6d3;
              font-family: 'DM Mono', monospace;
              font-size: 0.8rem;
              line-height: 1.8;
              resize: vertical;
              outline: none;
              transition: border-color 0.3s, box-shadow 0.3s;
            " %>
      </div>
      <%= f.submit "Save Letter", class: "btn-outline", style: "width:fit-content;cursor:pointer;" %>
    <% end %>

  </div>

</div>

<%# ---- IMAGE LIGHTBOX ---- %>
<dialog id="artwork-lightbox" style="background:transparent;border:none;margin:auto;max-width:92vw;max-height:92vh;padding:0;" class="backdrop:bg-black/90 backdrop:backdrop-blur-sm">
  <form method="dialog" style="display:flex;align-items:center;justify-content:center;height:100%;">
    <img id="artwork-lightbox-img" src="" style="max-width:90vw;max-height:90vh;object-fit:contain;border-radius:8px;">
    <button type="submit" style="position:fixed;top:1.5rem;right:1.5rem;background:rgba(26,22,18,0.9);backdrop-filter:blur(8px);border:1px solid #c4933f;color:#c4933f;width:2.5rem;height:2.5rem;border-radius:50%;font-size:1.5rem;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1;transition:all 0.2s;" onmouseover="this.style.background='#c4933f';this.style.color='#1a1612';" onmouseout="this.style.background='rgba(26,22,18,0.9)';this.style.color='#c4933f';">&times;</button>
  </form>
</dialog>

<script>
  function openArtworkLightbox(url) {
    document.getElementById('artwork-lightbox-img').src = url;
    document.getElementById('artwork-lightbox').showModal();
  }
  document.getElementById('artwork-lightbox').addEventListener('click', function(e) {
    if (e.target === this) this.close();
  });
</script>
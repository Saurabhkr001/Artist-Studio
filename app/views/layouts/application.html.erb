<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="turbo-cache-control" content="no-preview">
    <title>The Studio</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js" data-turbo-track="reload"></script>
    <%= javascript_importmap_tags %>

    <style>
      /* ── NAV ENTRANCE ── */
      @keyframes navSlideDown {
        from { transform: translateY(-100%); opacity: 0; }
        to   { transform: translateY(0); opacity: 1; }
      }
      .nav-animated {
        animation: navSlideDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }

      /* ── AVATAR HOVER ── */
      .avatar-wrap {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }
      .avatar-wrap:hover {
        transform: scale(1.08);
        box-shadow: 0 0 16px rgba(196, 147, 63, 0.25);
      }

      /* ── ADD ARTWORK BUTTON GLOW ── */
      .btn-add-artwork {
        position: relative;
        overflow: hidden;
        transition: all 0.3s ease;
      }
      .btn-add-artwork::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent);
        transition: left 0.5s ease;
      }
      .btn-add-artwork:hover {
        box-shadow: 0 0 20px rgba(196, 147, 63, 0.3);
        transform: translateY(-1px);
      }
      .btn-add-artwork:hover::before {
        left: 100%;
      }

      /* ── ACTIVE NAV INDICATOR ── */
      .nav-link-active {
        color: #c4933f !important;
        position: relative;
      }
      .nav-link-active::after {
        content: '';
        position: absolute;
        bottom: -4px;
        left: 50%;
        transform: translateX(-50%);
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: #c4933f;
      }

      /* ── TURBO PAGE TRANSITION ── */
      .turbo-progress-bar {
        height: 2px;
        background: linear-gradient(90deg, #c4933f, #f0d080);
      }
    </style>
  </head>

  <body class="h-full bg-canvas font-sans antialiased">

    <% if user_signed_in? %>
      <nav class="nav-animated bg-canvas2 border-b border-canvas3 px-4 md:px-8 py-4 flex flex-wrap items-center justify-between gap-4 min-w-0">
        <div class="flex flex-wrap items-center gap-4 md:gap-10 min-w-0">
          <%= link_to root_path, class: "font-display text-2xl italic text-cream whitespace-nowrap flex-shrink-0" do %>
            The Studio
          <% end %>
          
          <div class="flex flex-wrap items-center gap-4 md:gap-6">
            <%= link_to "All Works", artworks_path,
                class: "font-mono text-xs uppercase tracking-widest text-stone-500 hover:text-cream transition-colors whitespace-nowrap relative #{controller_name == 'artworks' && action_name == 'index' ? 'nav-link-active' : ''}" %>
            <%= link_to "Analytics", analytics_path,
                class: "font-mono text-xs uppercase tracking-widest text-stone-500 hover:text-cream transition-colors whitespace-nowrap relative #{controller_name == 'home' && action_name == 'analytics' ? 'nav-link-active' : ''}" %>
            <%= link_to "Portfolio ↗", portfolio_path,
                class: "font-mono text-xs uppercase tracking-widest text-stone-500 hover:text-cream transition-colors whitespace-nowrap",
                target: "_blank" %>
          </div>
        </div>

        <div class="flex flex-wrap items-center gap-4 md:gap-6 flex-shrink-0">
          <%= link_to "+ Add Artwork", new_artwork_path,
              class: "btn-add-artwork font-mono text-xs uppercase tracking-widest border border-ochre text-ochre px-4 py-2 hover:bg-ochre hover:text-canvas whitespace-nowrap" %>
          
          <div class="hidden sm:block h-6 w-px bg-stone-800"></div>
          
          <%= link_to edit_profile_path,
              class: "avatar-wrap flex items-center gap-2.5 font-mono text-xs uppercase tracking-widest text-stone-500 hover:text-cream transition-colors whitespace-nowrap" do %>
            <% if current_user.avatar.attached? %>
              <%= image_tag current_user.avatar.variant(resize_to_fill: [64, 64]),
                            class: "w-8 h-8 flex-shrink-0 rounded-full object-cover border border-stone-600 ring-1 ring-stone-700" %>
          <% else %>
            <div class="w-8 h-8 flex-shrink-0 rounded-full flex items-center justify-center border border-stone-600 ring-1 ring-stone-700 bg-stone-900" style="background: #1a1612 !important;">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9.06 11.9 8.07-8.06a2.85 2.85 0 1 1 4.03 4.03l-8.06 8.08"/>
                <path d="M7.07 14.94c-1.66 0-3 1.35-3 3.02 0 1.33-2.5 1.52-2 2.02 1.08 1.1 2.49 2.02 4 2.02 2.2 0 4-1.8 4-4.04a3.01 3.01 0 0 0-3-3.02z"/>
              </svg>
            </div>
            <% end %>
          <% end %>

          <%= link_to "Sign Out", destroy_user_session_path,
              data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to sign out?", confirm_button_text: "Sign Out" },
              class: "font-mono text-xs uppercase tracking-widest text-stone-600 hover:text-cream transition-colors whitespace-nowrap" %>
        </div>
      </nav>
    <% end %>

    <% if notice.present? %>
      <div id="toast-wrap" style="position:fixed;bottom:2rem;right:2rem;z-index:9999;pointer-events:none;">
        <div id="toast" style="
          pointer-events:all;
          background:rgba(26,22,18,0.95);
          backdrop-filter:blur(12px);
          -webkit-backdrop-filter:blur(12px);
          border:1px solid #c4933f;
          border-radius:16px 16px 4px 16px;
          padding:0.9rem 1.2rem 0.9rem 1rem;
          display:flex;
          align-items:flex-start;
          gap:0.75rem;
          max-width:280px;
          box-shadow:0 4px 24px rgba(0,0,0,0.5), 0 0 30px rgba(196,147,63,0.08);
          transform:translateY(20px);
          opacity:0;
          transition:transform 0.35s cubic-bezier(0.34,1.56,0.64,1),opacity 0.3s ease;
          position:relative;
        ">
          <div style="
            width:28px;height:28px;border-radius:50%;
            background:#2a251e;border:1px solid #c4933f;
            display:flex;align-items:center;justify-content:center;
            flex-shrink:0;margin-top:1px;
          ">
            <span style="color:#c4933f;font-size:0.8rem;">✓</span>
          </div>
          <div style="flex:1;min-width:0;">
            <p style="font-family:'DM Mono',monospace;font-size:0.7rem;color:#f0e6d3;line-height:1.5;margin:0;">
              <%= notice %>
            </p>
            <div id="toast-bar" style="
              height:2px;background:#c4933f;border-radius:1px;
              margin-top:0.6rem;width:100%;
              transform-origin:left;
              animation:shrink 3s linear forwards;
            "></div>
          </div>
          <button onclick="dismissToast()" style="
            background:none;border:none;cursor:pointer;
            color:#3a3028;font-size:1rem;padding:0;
            line-height:1;flex-shrink:0;margin-top:1px;
            font-family:'DM Mono',monospace;
          ">&times;</button>

          <div style="
            position:absolute;
            bottom:-6px;right:16px;
            width:0;height:0;
            border-left:6px solid transparent;
            border-right:6px solid transparent;
            border-top:6px solid #c4933f;
          "></div>
        </div>
      </div>

      <style>
        @keyframes shrink {
          from { transform: scaleX(1); }
          to   { transform: scaleX(0); }
        }
      </style>

      <script>
        (function() {
          var t = document.getElementById('toast');
          requestAnimationFrame(function() {
            requestAnimationFrame(function() {
              t.style.transform = 'translateY(0)';
              t.style.opacity   = '1';
            });
          });

          var timer = setTimeout(dismissToast, 3000);

          function dismissToast() {
            clearTimeout(timer);
            t.style.transform = 'translateY(20px)';
            t.style.opacity   = '0';
            setTimeout(function() {
              var w = document.getElementById('toast-wrap');
              if (w) w.remove();
            }, 350);
          }

          window.dismissToast = dismissToast;
        })();
      </script>
    <% end %>
    
    <% if alert.present? %>
      <% unless alert == "You need to sign in or sign up before continuing." && controller_name == 'sessions' && action_name == 'new' %>
        <div id="alert-wrap" style="position:fixed;bottom:2rem;left:2rem;z-index:9999;pointer-events:none;">
          <div id="alert-toast" style="
            pointer-events:all;
            background:rgba(26,22,18,0.95);
            backdrop-filter:blur(12px);
            -webkit-backdrop-filter:blur(12px);
            border:1px solid #a83232;
            border-radius:16px 16px 16px 4px;
            padding:0.9rem 1.2rem 0.9rem 1rem;
            display:flex;
            align-items:flex-start;
            gap:0.75rem;
            max-width:280px;
            box-shadow:0 4px 24px rgba(0,0,0,0.5);
            transform:translateY(20px);
            opacity:0;
            transition:transform 0.35s cubic-bezier(0.34,1.56,0.64,1),opacity 0.3s ease;
            position:relative;
          ">
            <div style="
              width:28px;height:28px;border-radius:50%;
              background:#2a1a1a;border:1px solid #a83232;
              display:flex;align-items:center;justify-content:center;
              flex-shrink:0;margin-top:1px;
            ">
              <span style="color:#e05555;font-size:0.85rem;">✕</span>
            </div>
            <div style="flex:1;min-width:0;">
              <p style="font-family:'DM Mono',monospace;font-size:0.7rem;color:#f0e6d3;line-height:1.5;margin:0;">
                <%= alert %>
              </p>
              <div style="
                height:2px;background:#a83232;border-radius:1px;
                margin-top:0.6rem;width:100%;
                transform-origin:left;
                animation:shrink 4s linear forwards;
              "></div>
            </div>
            <button onclick="dismissAlert()" style="
              background:none;border:none;cursor:pointer;
              color:#3a3028;font-size:1rem;padding:0;
              line-height:1;flex-shrink:0;margin-top:1px;
              font-family:'DM Mono',monospace;
            ">&times;</button>

            <div style="
              position:absolute;
              bottom:-6px;left:16px;
              width:0;height:0;
              border-left:6px solid transparent;
              border-right:6px solid transparent;
              border-top:6px solid #a83232;
            "></div>
          </div>
        </div>

        <script>
          (function() {
            var t = document.getElementById('alert-toast');
            requestAnimationFrame(function() {
              requestAnimationFrame(function() {
                t.style.transform = 'translateY(0)';
                t.style.opacity   = '1';
              });
            });

            var timer = setTimeout(dismissAlert, 4000);

            function dismissAlert() {
              clearTimeout(timer);
              t.style.transform = 'translateY(20px)';
              t.style.opacity   = '0';
              setTimeout(function() {
                var w = document.getElementById('alert-wrap');
                if (w) w.remove();
              }, 350);
            }

            window.dismissAlert = dismissAlert;
          })();
        </script>
      <% end %>
    <% end %>

    <% if devise_controller? %>
      <main>
        <%= yield %>
      </main>
    <% else %>
      <main class="max-w-7xl mx-auto px-8 py-12">
        <%= yield %>
      </main>

      <footer class="mt-24 border-t border-canvas3 px-8 py-10 text-center font-mono text-xs text-stone-600">
        <div class="divider-ochre mb-6" style="max-width:200px;margin-left:auto;margin-right:auto;"></div>
        Built with love, questionable taste, and way too many commits.
        <br>
        <%= link_to "who made this?", "/credits", class: "underline hover:text-ochre transition-colors mt-2 inline-block" %>
      </footer>
    <% end %>

    <dialog id="turbo-confirm" style="
      background:rgba(26,22,18,0.98);
      backdrop-filter:blur(16px);
      -webkit-backdrop-filter:blur(16px);
      border:1px solid #2e2920;
      border-radius:4px 20px 20px 20px;
      padding:0;
      max-width:320px;
      width:calc(100% - 2rem);
      margin:auto;
      box-shadow:0 24px 60px rgba(0,0,0,0.7), 0 0 40px rgba(196,147,63,0.05);
      outline:none;
    " class="backdrop:bg-black/70 backdrop:backdrop-blur-md">
      <form method="dialog">

        <%# Header %>
        <div style="padding:1.75rem 1.75rem 1.25rem; border-bottom:1px solid #2e2920;">
          <div style="display:flex;align-items:center;gap:0.875rem;margin-bottom:0.875rem;">
            <div style="
              width:34px;height:34px;flex-shrink:0;
              border:1px solid #c4933f;
              display:flex;align-items:center;justify-content:center;
            ">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c4933f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                <polyline points="16 17 21 12 16 7"/>
                <line x1="21" y1="12" x2="9" y2="12"/>
              </svg>
            </div>
            <span style="font-family:'DM Mono',monospace;font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:#5a5040;">Confirmation required</span>
          </div>
          <p style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-style:italic;color:#f0e6d3;margin:0 0 0.4rem;line-height:1.2;">Sign out?</p>
          <p id="turbo-confirm-message" style="font-family:'DM Mono',monospace;font-size:0.7rem;color:#6b5f4e;line-height:1.6;margin:0;"></p>
        </div>

        <%# Actions %>
        <div style="display:flex;">
          <button value="cancel" autofocus style="
            flex:1;
            font-family:'DM Mono',monospace;
            font-size:0.65rem;
            letter-spacing:0.12em;
            text-transform:uppercase;
            color:#5a5040;
            background:transparent;
            border:none;
            border-right:1px solid #2e2920;
            padding:1.1rem;
            cursor:pointer;
            transition:color 0.2s, background 0.2s;
          " onmouseover="this.style.color='#f0e6d3';this.style.background='#211d18'"
            onmouseout="this.style.color='#5a5040';this.style.background='transparent'">
            Cancel
          </button>
          <button value="confirm" id="turbo-confirm-accept" style="
            flex:1;
            font-family:'DM Mono',monospace;
            font-size:0.65rem;
            letter-spacing:0.12em;
            text-transform:uppercase;
            color:#c4933f;
            background:transparent;
            border:none;
            padding:1.1rem;
            cursor:pointer;
            transition:color 0.2s, background 0.2s;
          " onmouseover="this.style.color='#1a1612';this.style.background='#c4933f'"
            onmouseout="this.style.color='#c4933f';this.style.background='transparent'">
            Sign out
          </button>
        </div>

      </form>
    </dialog>

    <script>
      document.addEventListener("turbo:confirm", (event) => {
        event.preventDefault();
        const dialog = document.getElementById("turbo-confirm");
        document.getElementById("turbo-confirm-message").textContent = event.detail.message;
        
        const confirmButton = document.getElementById("turbo-confirm-accept");
        const customText = event.target.getAttribute("data-confirm-button-text") || "Confirm";
        confirmButton.textContent = customText;

        dialog.returnValue = "";
        dialog.showModal();
        dialog.addEventListener("close", () => {
          if (dialog.returnValue === "confirm") {
            event.detail.resume();
          }
        }, { once: true });
      });

      // ── INTERSECTION OBSERVER FOR FADE-INS ──
      document.addEventListener("turbo:load", initFadeIns);
      document.addEventListener("DOMContentLoaded", initFadeIns);

      function initFadeIns() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              observer.unobserve(e.target);
            }
          });
        }, { threshold: 0.08 });
        document.querySelectorAll('.fade-in-up').forEach(el => observer.observe(el));
      }
    </script>
  </body>
</html>
<div class="space-y-12">

  <%# ---- HEADER ---- %>
  <div class="fade-in-up flex items-center justify-between">
    <div>
      <h1 style="font-family:'Cormorant Garamond',serif;font-size:2.5rem;font-style:italic;font-weight:300;color:#f0e6d3;line-height:1;">
        <%= current_user.display_name %>'s Studio
      </h1>
      <p style="font-family:'DM Mono',monospace;font-size:0.7rem;color:#5a4e3a;margin-top:0.4rem;letter-spacing:0.1em;">
        Welcome back. Here's where things stand.
      </p>
    </div>
    <%= link_to "Add Artwork", new_artwork_path,
        class: "btn-primary",
        style: "text-decoration:none;display:inline-block;" %>
  </div>

  <%# ---- STATS ROW ---- %>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <% [
      ["Total Works", @counts[:total], "#c4933f", '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>'],
      ["Available",   @counts[:available], "#4a7c59", '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>'],
      ["Sold",        @counts[:sold], "#3d6b9e", '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>'],
      ["In Progress", @counts[:in_progress], "#8a6a3a", '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9.06 11.9 8.07-8.06a2.85 2.85 0 1 1 4.03 4.03l-8.06 8.08"/><path d="M7.07 14.94c-1.66 0-3 1.35-3 3.02 0 1.33-2.5 1.52-2 2.02 1.08 1.1 2.49 2.02 4 2.02 2.2 0 4-1.8 4-4.04a3.01 3.01 0 0 0-3-3.02z"/></svg>'],
    ].each_with_index do |(label, count, color, icon), idx| %>
      <div class="glass-card fade-in-up stagger-<%= idx + 1 %>" style="padding:1.25rem;position:relative;overflow:hidden;">
        <!-- Accent bar -->
        <div style="position:absolute;top:0;right:0;width:3px;height:100%;background:<%= color %>;"></div>
        <!-- Icon -->
        <div style="width:36px;height:36px;border-radius:50%;background:rgba(0,0,0,0.3);border:1px solid <%= color %>33;display:flex;align-items:center;justify-content:center;color:<%= color %>;margin-bottom:0.75rem;">
          <%= icon.html_safe %>
        </div>
        <!-- Number -->
        <div class="stat-counter" data-target="<%= count %>" style="font-family:'Cormorant Garamond',serif;font-size:2.5rem;font-weight:300;color:#f0e6d3;line-height:1;">
          0
        </div>
        <!-- Label -->
        <div style="font-family:'DM Mono',monospace;font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:#5a4e3a;margin-top:0.4rem;">
          <%= label %>
        </div>
        <!-- Progress bar -->
        <div style="height:2px;border-radius:1px;margin-top:0.75rem;background:rgba(255,255,255,0.04);">
          <div style="height:100%;border-radius:1px;background:<%= color %>;width:<%= @counts[:total] > 0 ? (count.to_f / @counts[:total] * 100).round : 0 %>%;transition:width 1.2s ease;"></div>
        </div>
      </div>
    <% end %>
  </div>

  <%# ---- THIS DAY IN YOUR STUDIO ---- %>
  <% if @artworks_today.any? %>
    <div class="fade-in-up glass-card" style="padding:1.5rem;border-color:rgba(196,147,63,0.15);">
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
        <div style="width:8px;height:8px;border-radius:50%;background:#c4933f;box-shadow:0 0 8px rgba(196,147,63,0.5);animation:pulse 2s ease-in-out infinite;"></div>
        <h2 style="font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-style:italic;font-weight:400;color:#f0d080;">
          This Day in Your Studio
        </h2>
      </div>
      <p style="font-family:'DM Mono',monospace;font-size:0.65rem;color:#8a7a65;margin-bottom:1.25rem;letter-spacing:0.05em;">
        On this day in past years, you were painting these:
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <% @artworks_today.each do |artwork| %>
          <%= link_to artwork_path(artwork.slug), class: "group" do %>
            <div class="aspect-square rounded-xl overflow-hidden artwork-card-wrap" style="background:#2a251e;">
              <% if artwork.images.attached? %>
                <%= image_tag artwork.images.first,
                    class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" %>
              <% end %>
              <div class="artwork-hover-overlay">
                <span class="overlay-title"><%= artwork.title %></span>
              </div>
            </div>
            <p style="font-family:'Cormorant Garamond',serif;font-size:0.95rem;font-style:italic;color:#f0e6d3;margin-top:0.5rem;">
              <%= artwork.title %>
            </p>
            <p style="font-family:'DM Mono',monospace;font-size:0.6rem;color:#5a4e3a;"><%= artwork.year_created %></p>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ---- RECENT WORKS ---- %>
  <div class="fade-in-up">
    <div class="flex items-center justify-between mb-5">
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-style:italic;font-weight:400;color:#f0e6d3;">
        Recent Works
      </h2>
      <%= link_to "View all →", artworks_path,
          style: "font-family:'DM Mono',monospace;font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:#5a4e3a;text-decoration:none;transition:color 0.2s;",
          onmouseover: "this.style.color='#c4933f'",
          onmouseout: "this.style.color='#5a4e3a'" %>
    </div>

    <% if @recent_artworks.any? %>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
        <% @recent_artworks.each_with_index do |artwork, idx| %>
          <%= link_to artwork_path(artwork.slug), class: "group fade-in-up stagger-#{idx + 1}", style: "text-decoration:none;" do %>
            <div class="aspect-square rounded-2xl overflow-hidden artwork-card-wrap glow-border" style="background:#1a1612;">
              <% if artwork.images.attached? %>
                <%= image_tag artwork.images.first,
                    class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center" style="color:#3a3028;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                </div>
              <% end %>
              <div class="artwork-hover-overlay">
                <span class="overlay-title"><%= artwork.title %></span>
                <span class="overlay-meta"><%= artwork.medium %> · <%= artwork.year_created %></span>
              </div>
            </div>
            <div class="mt-3">
              <p style="font-family:'Cormorant Garamond',serif;font-size:1.05rem;font-style:italic;color:#f0e6d3;transition:color 0.2s;">
                <%= artwork.title %>
              </p>
              <p style="font-family:'DM Mono',monospace;font-size:0.6rem;color:#5a4e3a;margin-top:0.2rem;">
                <%= artwork.medium %> · <%= artwork.year_created %>
              </p>
              <span style="display:inline-block;margin-top:0.4rem;font-family:'DM Mono',monospace;font-size:0.55rem;letter-spacing:0.1em;text-transform:uppercase;padding:0.2rem 0.6rem;border-radius:20px;
                background:<%= artwork.available? ? 'rgba(74,124,89,0.15)' : artwork.sold? ? 'rgba(61,107,158,0.15)' : 'rgba(42,37,30,0.5)' %>;
                color:<%= artwork.available? ? '#6ab87a' : artwork.sold? ? '#6a90d8' : '#5a4e3a' %>;
                border:1px solid <%= artwork.available? ? 'rgba(74,124,89,0.25)' : artwork.sold? ? 'rgba(61,107,158,0.25)' : 'rgba(42,37,30,0.5)' %>;">
                <%= artwork.status.humanize %>
              </span>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="glass-card" style="text-align:center;padding:4rem 2rem;">
        <div style="width:64px;height:64px;border-radius:50%;background:rgba(196,147,63,0.08);border:1px solid rgba(196,147,63,0.15);display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;color:#c4933f;">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
        </div>
        <p style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-style:italic;color:#f0e6d3;">No paintings yet.</p>
        <p style="font-family:'DM Mono',monospace;font-size:0.7rem;color:#3a3028;margin-top:0.5rem;">Which is ironic, given that you're a painter.</p>
        <%= link_to "Add your first artwork →", new_artwork_path,
            style: "display:inline-block;margin-top:1.25rem;font-family:'DM Mono',monospace;font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;color:#c4933f;border:1px solid #c4933f;padding:0.6rem 1.2rem;border-radius:4px;text-decoration:none;transition:all 0.2s;",
            onmouseover: "this.style.background='rgba(196,147,63,0.08)'",
            onmouseout: "this.style.background='transparent'" %>
      </div>
    <% end %>
  </div>

</div>

<style>
  @keyframes pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 8px rgba(196,147,63,0.5); }
    50% { opacity: 0.6; box-shadow: 0 0 16px rgba(196,147,63,0.8); }
  }
</style>

<script>
  // ── ANIMATED COUNTING ──
  document.addEventListener("turbo:load", initCounters);
  document.addEventListener("DOMContentLoaded", initCounters);

  function initCounters() {
    const counters = document.querySelectorAll('.stat-counter');
    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const target = parseInt(el.dataset.target, 10);
          if (target === 0) { el.textContent = '0'; counterObserver.unobserve(el); return; }
          const duration = 1200;
          const start = performance.now();
          function animate(now) {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            el.textContent = Math.round(eased * target);
            if (progress < 1) requestAnimationFrame(animate);
          }
          requestAnimationFrame(animate);
          counterObserver.unobserve(el);
        }
      });
    }, { threshold: 0.3 });
    counters.forEach(c => counterObserver.observe(c));
  }
</script>
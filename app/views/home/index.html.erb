<div class="space-y-12">

  <%# ---- HEADER ---- %>
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-stone-900"><%= current_user.display_name %>'s Studio</h1>
      <p class="text-stone-500 mt-1">Welcome back. Here's where things stand.</p>
    </div>
    <%= link_to "Add Artwork", new_artwork_path,
        class: "bg-stone-900 text-white px-5 py-2.5 rounded-lg hover:bg-stone-700 text-sm font-medium" %>
  </div>

  <%# ---- STATS ROW ---- %>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <% [
      ["Total Works", @counts[:total], "🖼️"],
      ["Available",   @counts[:available], "🟢"],
      ["Sold",        @counts[:sold], "💸"],
      ["In Progress", @counts[:in_progress], "🎨"],
    ].each do |label, count, icon| %>
      <div class="bg-white rounded-xl border border-stone-200 px-5 py-4">
        <div class="text-2xl mb-1"><%= icon %></div>
        <div class="text-2xl font-bold text-stone-900"><%= count %></div>
        <div class="text-xs text-stone-500 mt-0.5"><%= label %></div>
      </div>
    <% end %>
  </div>

  <%# ---- THIS DAY IN YOUR STUDIO ---- %>
  <% if @artworks_today.any? %>
    <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6">
      <h2 class="text-lg font-semibold text-amber-900 mb-1">
        📅 This Day in Your Studio
      </h2>
      <p class="text-sm text-amber-700 mb-5">
        On this day in past years, you were painting these:
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <% @artworks_today.each do |artwork| %>
          <%= link_to artwork_path(artwork.slug), class: "group" do %>
            <div class="aspect-square bg-stone-200 rounded-xl overflow-hidden">
              <% if artwork.images.attached? %>
                <%= image_tag artwork.images.first,
                    class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" %>
              <% end %>
            </div>
            <p class="text-sm font-medium text-stone-800 mt-2 group-hover:text-amber-800">
              <%= artwork.title %>
            </p>
            <p class="text-xs text-stone-400"><%= artwork.year_created %></p>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ---- RECENT WORKS ---- %>
  <div>
    <div class="flex items-center justify-between mb-5">
      <h2 class="text-lg font-semibold text-stone-900">Recent Works</h2>
      <%= link_to "View all →", artworks_path, class: "text-sm text-stone-400 hover:text-stone-700" %>
    </div>

    <% if @recent_artworks.any? %>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
        <% @recent_artworks.each do |artwork| %>
          <%= link_to artwork_path(artwork.slug), class: "group" do %>
            <div class="aspect-square bg-stone-100 rounded-2xl overflow-hidden border border-stone-200">
              <% if artwork.images.attached? %>
                <%= image_tag artwork.images.first,
                    class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center text-stone-400 text-sm">
                  No image yet
                </div>
              <% end %>
            </div>
            <div class="mt-3">
              <p class="font-medium text-stone-900 group-hover:text-stone-600"><%= artwork.title %></p>
              <p class="text-xs text-stone-400 mt-0.5">
                <%= artwork.medium %> · <%= artwork.year_created %>
              </p>
              <span class="inline-block mt-1 text-xs px-2 py-0.5 rounded-full
                <%= artwork.available? ? 'bg-emerald-100 text-emerald-700' :
                    artwork.sold? ? 'bg-blue-100 text-blue-700' :
                    'bg-stone-100 text-stone-500' %>">
                <%= artwork.status.humanize %>
              </span>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-20 text-stone-400">
        <p class="text-4xl mb-3">🖼️</p>
        <p class="text-lg font-medium text-stone-600">No paintings yet.</p>
        <p class="text-sm mt-1">Which is ironic, given that you're a painter.</p>
        <%= link_to "Add your first artwork →", new_artwork_path,
            class: "mt-4 inline-block text-sm text-stone-900 underline" %>
      </div>
    <% end %>
  </div>

</div>
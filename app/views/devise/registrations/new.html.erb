<style>
  *, *::before, *::after { box-sizing: border-box; }

  :root {
    --glow-color:      #c4933f;
    --glow-color-dark: #8a6020;
    --glow-rgb:        196, 147, 63;
  }

  .auth-page-container {
    min-height: 100vh;
    background: #0d0d0f;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: "DM Mono", monospace;
    -webkit-font-smoothing: antialiased;
    position: relative;
    overflow: hidden;
  }

  .auth-page-container::after {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/feTurbulence%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1;
  }

  /* ── LAMP VISUALS (ALWAYS ON) ── */
  .lamp-cord {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: 80px;
    background: linear-gradient(to bottom, rgba(var(--glow-rgb), 0.5), transparent);
    z-index: 1;
    pointer-events: none;
  }

  .lamp-bulb {
    position: absolute;
    top: 76px;
    left: 50%;
    transform: translateX(-50%);
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--glow-color);
    box-shadow:
      0 0 8px 3px rgba(var(--glow-rgb), 0.9),
      0 0 20px 8px rgba(var(--glow-rgb), 0.5),
      0 0 40px 16px rgba(var(--glow-rgb), 0.2);
    z-index: 2;
    pointer-events: none;
    animation: bulbPulse 3s ease-in-out infinite;
  }

  @keyframes bulbPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.85; }
  }

  .lamp-cone {
    position: absolute;
    top: 80px;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 500px;
    background: radial-gradient(
      ellipse at center top,
      rgba(var(--glow-rgb), 0.14) 0%,
      rgba(var(--glow-rgb), 0.06) 30%,
      rgba(var(--glow-rgb), 0.02) 55%,
      transparent 70%
    );
    z-index: 0;
    pointer-events: none;
    animation: conePulse 3s ease-in-out infinite;
  }

  @keyframes conePulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.75; }
  }

  .floor-glow {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 150px;
    background: radial-gradient(
      ellipse at center bottom,
      rgba(var(--glow-rgb), 0.06) 0%,
      transparent 70%
    );
    z-index: 0;
    pointer-events: none;
  }

  /* ── CARD WRAPPER ── */
  .card-wrapper {
    position: relative;
    z-index: 10;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  /* ── CARD ── */
  .card {
    box-sizing: border-box;
    width: 100%;
    max-width: 400px;
    margin: 0 1rem;
    padding: 2.25rem 2rem;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.04) 0%, rgba(255, 255, 255, 0.01) 100%);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 16px;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow:
      0 30px 60px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(var(--glow-rgb), 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
    animation: cardRise 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes cardRise {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── HEADERS & TEXT ── */
  .card-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .card-title {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: 1.8rem;
    font-style: italic;
    font-weight: 300;
    color: #f0e6d3;
    line-height: 1;
    margin-bottom: 0.4rem;
  }

  .card-sub {
    font-size: 0.55rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgba(240, 230, 211, 0.25);
  }

  /* ── LABELS ── */
  label {
    display: block;
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(240, 230, 211, 0.4);
    margin-bottom: 0.4rem;
  }

  /* ── INPUTS ── */
  input[type="email"],
  input[type="password"],
  input[type="text"] {
    width: 100%;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    color: #f0e6d3;
    font-family: "DM Mono", monospace;
    font-size: 0.8rem;
    outline: none;
    transition: border-color 0.3s, box-shadow 0.3s, background 0.3s;
    -webkit-appearance: none;
  }

  input[type="email"]:focus,
  input[type="password"]:focus,
  input[type="text"]:focus {
    border-color: rgba(var(--glow-rgb), 0.4);
    background: rgba(255, 255, 255, 0.06);
    box-shadow:
      0 0 0 3px rgba(var(--glow-rgb), 0.08),
      0 0 15px rgba(var(--glow-rgb), 0.05);
  }

  input::placeholder { color: rgba(240, 230, 211, 0.2); }

  /* ── AUTOFILL FIX ── */
  input:-webkit-autofill,
  input:-webkit-autofill:hover,
  input:-webkit-autofill:focus,
  input:-webkit-autofill:active {
    -webkit-text-fill-color: #d4ae67 !important;
    transition: background-color 5000s ease-in-out 0s;
  }

  /* ── FIELD GROUPS ── */
  .field { margin-bottom: 1rem; }
  .field:last-of-type { margin-bottom: 0; }
  .fields { margin-bottom: 1.25rem; }

  /* ── GLOW BUTTON ── */
  .login-btn {
    width: 100%;
    padding: 0.8rem 1rem;
    background: linear-gradient(
      135deg,
      var(--glow-color),
      var(--glow-color-dark)
    );
    border: none;
    border-radius: 8px;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 600;
    font-family: "DM Mono", monospace;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow:
      0 4px 15px rgba(var(--glow-rgb), 0.3),
      0 0 30px rgba(var(--glow-rgb), 0.1);
    margin-top: 0.5rem;
    position: relative;
    overflow: hidden;
  }

  .login-btn::before {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.08),
      transparent
    );
    transition: left 0.5s ease;
  }

  .login-btn:hover {
    box-shadow:
      0 6px 25px rgba(var(--glow-rgb), 0.45),
      0 0 50px rgba(var(--glow-rgb), 0.18);
    transform: translateY(-1px);
  }

  .login-btn:hover::before { left: 100%; }
  .login-btn:active { transform: translateY(0) scale(0.99); }

  /* ── BOTTOM LINK ── */
  .card-footer {
    text-align: center;
    margin-top: 1.25rem;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    color: rgba(240, 230, 211, 0.2);
  }

  .card-footer a {
    color: rgba(240, 230, 211, 0.4);
    text-decoration: none;
    transition: color 0.2s;
  }

  .card-footer a:hover { color: rgba(var(--glow-rgb), 0.7); }

  /* ── TOAST POPUPS (FLASH) ── */
  .toast-container {
    position: fixed;
    top: 30px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 10px;
    pointer-events: none;
  }

  .toast {
    background: rgba(20, 10, 10, 0.85);
    border: 1px solid rgba(217, 79, 61, 0.4);
    box-shadow: 0 4px 15px rgba(217, 79, 61, 0.15);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: #f0e6d3;
    padding: 0.8rem 1.5rem;
    border-radius: 30px;
    font-family: "DM Mono", monospace;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-align: center;
    animation: toastEnter 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards, toastExit 0.4s ease 4s forwards;
  }

  @keyframes toastEnter {
    from { opacity: 0; transform: translateY(-20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes toastExit {
    from { opacity: 1; transform: translateY(0); }
    to   { opacity: 0; transform: translateY(-20px); }
  }

  /* ── CLICK BUBBLES ── */
  .click-bubble {
    position: fixed;
    transform: translate(-50%, -50%);
    background: rgba(20, 10, 10, 0.9);
    border: 1px solid rgba(var(--glow-rgb), 0.4);
    box-shadow: 0 4px 15px rgba(var(--glow-rgb), 0.15);
    color: #f0e6d3;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-family: "DM Mono", monospace;
    font-size: 0.65rem;
    pointer-events: none;
    z-index: 9999;
    animation: floatUpFade 2.5s ease-out forwards;
    white-space: nowrap;
  }

  @keyframes floatUpFade {
    0%   { opacity: 1; transform: translate(-50%, -50%) scale(0.8); }
    100% { opacity: 0; transform: translate(-50%, calc(-50% - 50px)) scale(1); }
  }

  /* Responsive refinements */
  @media (max-width: 480px) {
    .card { padding: 2rem 1.5rem; border-radius: 14px; margin: 0 1rem; }
    .card-title { font-size: 1.6rem; }
    .lamp-cone { width: 100vw; }
  }
</style>

<div class="auth-page-container">
  <div class="toast-container">
    <% flash.each do |key, value| %>
      <div class="toast"><%= value %></div>
    <% end %>
    <% resource.errors.full_messages.each do |msg| %>
      <div class="toast"><%= msg %></div>
    <% end %>
  </div>

  <div class="lamp-cord"></div>
  <div class="lamp-bulb"></div>
  <div class="lamp-cone"></div>
  <div class="floor-glow"></div>

  <div class="card-wrapper">
    <div class="card">
        <div class="card-header">
          <h1 class="card-title">Join The Studio</h1>
          <p class="card-sub">Create your private art archive</p>
        </div>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
          <div class="fields">
            <div class="field">
              <%= f.label :name %>
              <%= f.text_field :name, autofocus: true, autocomplete: "name", placeholder: "Your Name" %>
            </div>

            <div class="field">
              <%= f.label :email %>
              <%= f.email_field :email, autocomplete: "email", placeholder: "your@email.com" %>
            </div>

            <div class="field">
              <div style="display: flex; justify-content: space-between; align-items: baseline;">
                <%= f.label :password %>
                <% if @minimum_password_length %>
                  <span style="font-size: 0.45rem; letter-spacing: 0.1em; color: rgba(240, 230, 211, 0.3); text-transform: uppercase;">(<%= @minimum_password_length %> chars min)</span>
                <% end %>
              </div>
              <%= f.password_field :password, autocomplete: "new-password", placeholder: "••••••••" %>
            </div>

            <div class="field">
              <%= f.label :password_confirmation %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••" %>
            </div>
          </div>

          <%= f.submit "Create Account", class: "login-btn" %>
        <% end %>

        <div class="card-footer">
          Already have an account?
          <%= link_to "Sign In", new_user_session_path %>
        </div>
      </div>
    </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // Add floating effects on click, customized for sign up
    document.addEventListener("click", (e) => {
      // Avoid spawning bubbles if they are interacting with the form or clicking links
      if (!e.target.closest('.card') && e.target.tagName.toLowerCase() !== 'a') {
        const bubble = document.createElement("div");
        bubble.className = "click-bubble";
        
        const phrases = [
          "✨ Creating space...",
          "🎨 Preparing your studio...",
          "💡 Sparking inspiration...",
          "🖼️ Making room for art..."
        ];
        bubble.innerText = phrases[Math.floor(Math.random() * phrases.length)];
        
        bubble.style.left = `${e.clientX}px`;
        bubble.style.top = `${e.clientY}px`;
        document.body.appendChild(bubble);
        
        setTimeout(() => bubble.remove(), 2500);
      }
    });
  });
</script>
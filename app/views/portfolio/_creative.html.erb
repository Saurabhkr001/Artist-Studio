<div class="creative-mode" style="overflow-y: auto; height: 100vh; overflow-x: hidden;">
  
  <% if @user.cover_image.attached? %>
    <div style="position: absolute; inset: 0; z-index: 0; background-image: url('<%= url_for(@user.cover_image) %>'); background-size: cover; background-position: center; opacity: 0.15; pointer-events: none;"></div>
  <% end %>

  <div class="creative-bg-text"><%= @user.display_name.upcase %></div>

  <div class="creative-slider-wrapper" id="works">
    <div class="creative-slider" id="creative-slider">
      <% if @artworks.any? %>
        <% @artworks.each do |artwork| %>
          <%= link_to portfolio_artwork_path(artwork.slug), class: "creative-slide" do %>
            <div class="creative-img-wrap">
              <% if artwork.images.attached? %>
                <%= image_tag artwork.images.first, class: "creative-img", alt: artwork.title %>
              <% else %>
                <div class="creative-placeholder">NO IMAGE</div>
              <% end %>
            </div>
            <div class="creative-info">
              <h2><%= artwork.title %></h2>
              <p><%= [artwork.year_created, artwork.medium].compact.join(" · ") %></p>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>
  <div class="creative-progress"><div class="creative-progress-bar"></div></div>

  <%# ABOUT SECTION %>
  <% if @user.artist_statement.present? %>
    <div class="creative-about-wrapper" id="about" style="position: relative; z-index: 50; margin-top: 100vh; background-color: #050505; width: 100%;">
      <div class="creative-about" style="padding: clamp(4rem, 10vw, 8rem) 1.5rem clamp(5rem, 10vw, 10rem) 1.5rem; max-width: 1000px; margin: 0 auto; display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: clamp(2rem, 5vw, 4rem);">
        <% if @user.avatar.attached? %>
          <div style="width: 100%; max-width: 270px; aspect-ratio: 1; border-radius: 50%; overflow: hidden; border: 2px solid rgba(255,255,255,0.3); box-shadow: 0 10px 30px rgba(0,0,0,0.5); flex-shrink: 0;">
            <%= image_tag @user.avatar, style: "width: 100%; height: 100%; object-fit: cover;", alt: @user.display_name %>
          </div>
        <% end %>
        <div style="flex: 1 1 min(100%, 300px); text-align: left;">
          <p style="color: #ff4d4d; font-family: 'DM Mono', monospace; text-transform: uppercase; letter-spacing: 0.2em; font-size: 0.7rem; margin-bottom: 1rem;">
            About the Artist
          </p>
          <h2 style="font-family: 'Space Grotesk', sans-serif; font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 700; line-height: 1.1; margin-bottom: 1.5rem; color: #fff;">
            <%= @user.display_name || @user.name %>
          </h2>
          <p style="font-family: 'Space Grotesk', sans-serif; font-size: 1.1rem; color: rgba(255,255,255,0.6); line-height: 1.8;">
            <%= @user.artist_statement %>
          </p>
        </div>
      </div>
    </div>
  <% end %>
</div>
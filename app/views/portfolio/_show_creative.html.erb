<div class="show-creative">
  <%# ── BLURRED BG ── %>
  <div class="sx-bg">
    <% if @artwork.images.attached? %>
      <%= image_tag @artwork.images.first, class: "sx-bg-img" %>
    <% end %>
    <div class="sx-bg-overlay"></div>
  </div>

  <%# ── CINEMATIC LAYOUT ── %>
  <div class="sx-stage">
    <%# Image side %>
    <div class="sx-image-col">
      <% if @artwork.images.attached? %>
        <div class="sx-image-frame">
          <%= image_tag @artwork.images.first, id: "main-img-creative", class: "sx-main-img" %>
        </div>
        <% if @artwork.images.count > 1 %>
          <div class="sx-thumb-strip">
            <% @artwork.images.each_with_index do |image, i| %>
              <div class="sx-thumb <%= i == 0 ? 'active' : '' %>"
                   onclick="document.getElementById('main-img-creative').src='<%= url_for(image) %>'; document.querySelectorAll('.sx-thumb').forEach(t => t.classList.remove('active')); this.classList.add('active')">
                <%= image_tag image, style: "width:100%;height:100%;object-fit:cover;" %>
              </div>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>

    <%# Info side %>
    <div class="sx-info-col">
      <div class="sx-info-inner">
        <p class="sx-meta-line">
          <%= [@artwork.medium, @artwork.year_created].compact.join(' — ') %>
        </p>
        <h1 class="sx-title"><%= @artwork.title %></h1>
        <div class="sx-red-line"></div>

        <p class="sx-description"><%= @artwork.description.presence || 'No description added yet.' %></p>

        <%# Data chips %>
        <div class="sx-chips">
          <div class="sx-chip"><%= @artwork.dimensions_cm.present? ? "#{@artwork.dimensions_cm} cm" : '—' %></div>
          <div class="sx-chip sx-chip-status" style="<%= @artwork.available? ? 'border-color:#ff4d4d;color:#ff4d4d;' : '' %>">
            <% if @artwork.available? %><span class="sx-chip-dot"></span><% end %>
            <%= @artwork.status.humanize %>
          </div>
        </div>

        <%# Progress bar decoration %>
        <div class="sx-progress-deco">
          <div class="sx-progress-fill"></div>
        </div>

        <a href="<%= portfolio_path %>" class="sx-back-btn">
          ← Back to Gallery
        </a>
      </div>
    </div>
  </div>
</div>
<div class="show-raw">
  <%# ── FULL-BLEED HERO ── %>
  <div class="sr-hero">
    <% if @artwork.images.attached? %>
      <div class="sr-hero-bg">
        <%= image_tag @artwork.images.first, id: "main-img-raw", class: "sr-hero-bg-img" %>
      </div>
    <% end %>
    <div class="sr-hero-grid"></div>
    <div class="sr-hero-content">
      <div class="sr-hero-eyebrow">
        <span class="sr-hero-line"></span>
        <span><%= [@artwork.year_created, @artwork.medium].compact.join(' · ') %></span>
      </div>
      <h1 class="sr-hero-title"><%= @artwork.title %></h1>
    </div>
    <div class="sr-hero-num">01</div>
  </div>

  <%# ── SPECS STRIP ── %>
  <div class="sr-specs-strip">
    <div class="sr-spec">
      <span class="sr-spec-label">MEDIUM</span>
      <span class="sr-spec-value"><%= @artwork.medium || '—' %></span>
    </div>
    <div class="sr-spec">
      <span class="sr-spec-label">YEAR</span>
      <span class="sr-spec-value"><%= @artwork.year_created.presence || '—' %></span>
    </div>
    <div class="sr-spec">
      <span class="sr-spec-label">DIMENSIONS</span>
      <span class="sr-spec-value"><%= @artwork.dimensions_cm.present? ? "#{@artwork.dimensions_cm} CM" : '—' %></span>
    </div>
    <div class="sr-spec">
      <span class="sr-spec-label">STATUS</span>
      <span class="sr-spec-value"><%= @artwork.status.upcase %></span>
    </div>
  </div>

  <%# ── IMAGE + DESCRIPTION ── %>
  <div class="sr-detail-section">
    <div class="sr-detail-grid">
      <div class="sr-detail-img-wrap">
        <% if @artwork.images.attached? %>
          <%= image_tag @artwork.images.first, class: "sr-detail-img" %>
          <% if @artwork.images.count > 1 %>
            <div class="sr-thumb-row">
              <% @artwork.images.each_with_index do |image, i| %>
                <div class="sr-thumb <%= i == 0 ? 'active' : '' %>"
                     onclick="document.getElementById('main-img-raw').src='<%= url_for(image) %>'; document.querySelector('.sr-detail-img').src='<%= url_for(image) %>'; document.querySelectorAll('.sr-thumb').forEach(t => t.classList.remove('active')); this.classList.add('active')">
                  <%= image_tag image, style: "width:100%;height:100%;object-fit:cover;" %>
                </div>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
      <div class="sr-detail-text">
        <div class="sr-section-label">
          <span class="sr-section-num">02</span>
          <span>DETAILS</span>
        </div>
        <p class="sr-description"><%= @artwork.description.presence || 'No description added yet.' %></p>
        <a href="<%= portfolio_path %>" class="sr-back-btn">
          <span>← BACK TO WORKS</span>
          <span class="sr-btn-arrow">→</span>
        </a>
      </div>
    </div>
  </div>
</div>
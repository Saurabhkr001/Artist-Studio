<div class="show-classic">
  <main style="max-width: 1100px; margin: 0 auto; padding: 5rem 2rem;">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: start;">
      <div>
        <% if @artwork.images.attached? %>
          <div style="background: #1a1612; border-radius: 4px; overflow: hidden;">
            <%= image_tag @artwork.images.first,
                id: "main-img",
                class: "artwork-frame",
                style: "width: 100%; display: block;" %>
          </div>
          <% if @artwork.images.count > 1 %>
            <div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 0.5rem; margin-top: 0.75rem;">
              <% @artwork.images.each_with_index do |image, i| %>
                <div class="thumb <%= i == 0 ? 'active' : '' %>"
                     style="border-radius: 3px; overflow: hidden; background: #1a1612;"
                     onclick="document.getElementById('main-img').src='<%= url_for(image) %>'; document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active')); this.classList.add('active')">
                  <%= image_tag image, class: "artwork-frame", style: "width: 100%; display: block; aspect-ratio: 1; object-fit: cover;" %>
                </div>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>

      <div style="padding-top: 1rem;">
        <p style="font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); margin-bottom: 1.5rem;">
          <%= @artwork.medium %>
        </p>
        <h1 class="font-display" style="font-size: clamp(2.5rem, 4vw, 3.5rem); font-style: italic; font-weight: 300; line-height: 1.1; margin-bottom: 2.5rem; color: var(--cream);">
          <%= @artwork.title %>
        </h1>
        <div style="width: 30px; height: 1px; background: var(--gold); margin-bottom: 2.5rem;"></div>

        <div style="display: grid; gap: 1.5rem;">
          <div>
            <p style="font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--dimmed); margin-bottom: 0.3rem;">Year</p>
            <p style="color: var(--cream2); font-size: 0.85rem;"><%= @artwork.year_created.presence || '—' %></p>
          </div>
          <div>
            <p style="font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--dimmed); margin-bottom: 0.3rem;">Dimensions</p>
            <p style="color: var(--cream2); font-size: 0.85rem;"><%= @artwork.dimensions_cm.present? ? "#{@artwork.dimensions_cm} cm" : '—' %></p>
          </div>
          <div>
            <p style="font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--dimmed); margin-bottom: 0.5rem;">About</p>
            <p style="color: var(--muted); font-size: 0.8rem; line-height: 1.8;"><%= @artwork.description.presence || 'No description added yet.' %></p>
          </div>
          <div style="padding-top: 1rem; border-top: 1px solid var(--border);">
            <span style="font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; padding: 0.4rem 1rem; border-radius: 2rem; border: 1px solid <%= @artwork.available? ? 'var(--green)' : 'var(--border2)' %>; color: <%= @artwork.available? ? 'var(--green)' : 'var(--muted)' %>;">
              <%= @artwork.status.humanize %>
            </span>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>